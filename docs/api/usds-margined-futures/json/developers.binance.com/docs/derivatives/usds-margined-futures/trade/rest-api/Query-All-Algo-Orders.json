{
  "title": "Query All Algo Orders (USER_DATA)",
  "meta_description": "API Description",
  "intro_blocks": [],
  "sections": [
    {
      "title": "API Description",
      "level": 2,
      "id": "api-description",
      "blocks": [
        {
          "type": "paragraph",
          "text": "Get all algo orders; active, CANCELED, TRIGGERED or FINISHED ."
        },
        {
          "type": "list",
          "ordered": false,
          "items": [
            {
              "text": "These orders will not be found: order status is `CANCELED` or `EXPIRED` AND order has NO filled trade AND created time + 3 days < current time order create time + 90 days < current time",
              "blocks": [
                {
                  "type": "list",
                  "ordered": false,
                  "items": [
                    {
                      "text": "order status is `CANCELED` or `EXPIRED` AND order has NO filled trade AND created time + 3 days < current time",
                      "blocks": []
                    },
                    {
                      "text": "order create time + 90 days < current time",
                      "blocks": []
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "title": "HTTP Request",
      "level": 2,
      "id": "http-request",
      "blocks": [
        {
          "type": "paragraph",
          "text": "GET `/fapi/v1/allAlgoOrders`"
        }
      ]
    },
    {
      "title": "Request Weight",
      "level": 2,
      "id": "request-weight",
      "blocks": [
        {
          "type": "paragraph",
          "text": "5"
        }
      ]
    },
    {
      "title": "Request Parameters",
      "level": 2,
      "id": "request-parameters",
      "blocks": [
        {
          "type": "table",
          "headers": [
            "Name",
            "Type",
            "Mandatory",
            "Description"
          ],
          "rows": [
            [
              "symbol",
              "STRING",
              "YES",
              ""
            ],
            [
              "algoId",
              "LONG",
              "NO",
              ""
            ],
            [
              "startTime",
              "LONG",
              "NO",
              ""
            ],
            [
              "endTime",
              "LONG",
              "NO",
              ""
            ],
            [
              "page",
              "INT",
              "NO",
              ""
            ],
            [
              "limit",
              "INT",
              "NO",
              "Default 500; max 1000."
            ],
            [
              "recvWindow",
              "LONG",
              "NO",
              ""
            ],
            [
              "timestamp",
              "LONG",
              "YES",
              ""
            ]
          ]
        },
        {
          "type": "paragraph",
          "text": "Notes:"
        },
        {
          "type": "blockquote",
          "text": "If `algoId` is set, it will get orders >= that `algoId`. Otherwise most recent orders are returned. The query time period must be less then 7 days( default as the recent 7 days)."
        }
      ]
    },
