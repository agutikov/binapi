{
  "title": "Current All Algo Open Orders (USER_DATA)",
  "meta_description": "API Description",
  "intro_blocks": [],
  "sections": [
    {
      "title": "API Description",
      "level": 2,
      "id": "api-description",
      "blocks": [
        {
          "type": "paragraph",
          "text": "Get all algo open orders on a symbol."
        }
      ]
    },
    {
      "title": "HTTP Request",
      "level": 2,
      "id": "http-request",
      "blocks": [
        {
          "type": "paragraph",
          "text": "GET `/fapi/v1/openAlgoOrders`"
        }
      ]
    },
    {
      "title": "Request Weight",
      "level": 2,
      "id": "request-weight",
      "blocks": [
        {
          "type": "paragraph",
          "text": "1 for a single symbol; 40 when the symbol parameter is omitted"
        },
        {
          "type": "paragraph",
          "text": "Careful when accessing this with no symbol."
        }
      ]
    },
    {
