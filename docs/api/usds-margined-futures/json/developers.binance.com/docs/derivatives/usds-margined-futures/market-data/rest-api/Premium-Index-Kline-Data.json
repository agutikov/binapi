{
  "title": "Premium index Kline Data",
  "meta_description": "API Description",
  "intro_blocks": [],
  "sections": [
    {
      "title": "API Description",
      "level": 2,
      "id": "api-description",
      "blocks": [
        {
          "type": "paragraph",
          "text": "Premium index kline bars of a symbol. Klines are uniquely identified by their open time."
        }
      ]
    },
    {
      "title": "HTTP Request",
      "level": 2,
      "id": "http-request",
      "blocks": [
        {
          "type": "paragraph",
          "text": "GET `/fapi/v1/premiumIndexKlines`"
        }
      ]
    },
    {
      "title": "Request Weight",
      "level": 2,
      "id": "request-weight",
      "blocks": [
        {
          "type": "paragraph",
          "text": "based on parameter `LIMIT`"
        },
        {
          "type": "table",
          "headers": [
            "LIMIT",
            "weight"
          ],
          "rows": [
            [
              "[1,100)",
              "1"
            ],
            [
              "[100, 500)",
              "2"
            ],
            [
              "[500, 1000]",
              "5"
            ],
            [
              "> 1000",
              "10"
            ]
          ]
        }
      ]
    },
    {
      "title": "Request Parameters",
      "level": 2,
      "id": "request-parameters",
      "blocks": [
        {
          "type": "table",
          "headers": [
            "Name",
            "Type",
            "Mandatory",
            "Description"
          ],
          "rows": [
            [
              "symbol",
              "STRING",
              "YES",
              ""
            ],
            [
              "interval",
              "ENUM",
              "YES",
              ""
            ],
            [
              "startTime",
              "LONG",
              "NO",
              ""
            ],
            [
              "endTime",
              "LONG",
              "NO",
              ""
            ],
            [
              "limit",
              "INT",
              "NO",
              "Default 500; max 1500."
            ]
          ]
        },
        {
          "type": "blockquote",
          "text": "If startTime and endTime are not sent, the most recent klines are returned."
        }
      ]
    },
    {
      "title": "Response Example",
      "level": 2,
      "id": "response-example",
      "blocks": [
        {
          "type": "code",
          "language": "javascript",
          "text": "[\n[\n1691603820000, // Open time\n\"-0.00042931\", // Open\n\"-0.00023641\", // High\n\"-0.00059406\", // Low\n\"-0.00043659\", // Close\n\"0\", // Ignore\n1691603879999, // Close time\n\"0\", // Ignore\n12, // Ignore\n\"0\", // Ignore\n\"0\", // Ignore\n\"0\" // Ignore\n]\n]"
        }
      ]
    }
  ],
