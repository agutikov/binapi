{
  "title": "Send Quote Request(USER_DATA)",
  "meta_description": "API Description",
  "intro_blocks": [],
  "sections": [
    {
      "title": "API Description",
      "level": 2,
      "id": "api-description",
      "blocks": [
        {
          "type": "paragraph",
          "text": "Request a quote for the requested token pairs"
        }
      ]
    },
    {
      "title": "HTTP Request",
      "level": 2,
      "id": "http-request",
      "blocks": [
        {
          "type": "paragraph",
          "text": "POST `/fapi/v1/convert/getQuote`"
        }
      ]
    },
    {
      "title": "Request Weight",
      "level": 2,
      "id": "request-weight",
      "blocks": [
        {
          "type": "paragraph",
          "text": "50(IP)"
        },
        {
          "type": "paragraph",
          "text": "360/hour，500/day"
        }
      ]
    },
    {
      "title": "Request Parameters",
      "level": 2,
      "id": "request-parameters",
      "blocks": [
        {
          "type": "table",
          "headers": [
            "Name",
            "Type",
            "Mandatory",
            "Description"
          ],
          "rows": [
            [
              "fromAsset",
              "STRING",
              "YES",
              ""
            ],
            [
              "toAsset",
              "STRING",
              "YES",
              ""
            ],
            [
              "fromAmount",
              "DECIMAL",
              "EITHER",
              "When specified, it is the amount you will be debited after the conversion"
            ],
            [
              "toAmount",
              "DECIMAL",
              "EITHER",
              "When specified, it is the amount you will be credited after the conversion"
            ],
            [
              "validTime",
              "ENUM",
              "NO",
              "10s, default 10s"
            ],
            [
              "recvWindow",
              "LONG",
              "NO",
              "The value cannot be greater than 60000"
            ],
            [
              "timestamp",
              "LONG",
              "YES",
              ""
            ]
          ]
        },
        {
          "type": "list",
          "ordered": false,
          "items": [
            {
              "text": "Either fromAmount or toAmount should be sent",
              "blocks": []
            },
            {
              "text": "`quoteId` will be returned only if you have enough funds to convert",
              "blocks": []
            }
          ]
        }
      ]
    },
    {
      "title": "Response Example",
      "level": 2,
      "id": "response-example",
      "blocks": [
        {
          "type": "code",
          "language": "json",
          "json": {
            "quoteId": "12415572564",
            "ratio": "38163.7",
            "inverseRatio": "0.0000262",
            "validTimestamp": 1623319461670,
            "toAmount": "3816.37",
            "fromAmount": "0.1"
          }
        }
      ]
    }
  ],
