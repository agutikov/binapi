{
  "title": "User's Force Orders (USER_DATA)",
  "meta_description": "API Description",
  "intro_blocks": [],
  "sections": [
    {
      "title": "API Description",
      "level": 2,
      "id": "api-description",
      "blocks": [
        {
          "type": "paragraph",
          "text": "Query user's Force Orders"
        }
      ]
    },
    {
      "title": "HTTP Request",
      "level": 2,
      "id": "http-request",
      "blocks": [
        {
          "type": "paragraph",
          "text": "GET `/fapi/v1/forceOrders`"
        }
      ]
    },
    {
      "title": "Request Weight",
      "level": 2,
      "id": "request-weight",
      "blocks": [
        {
          "type": "paragraph",
          "text": "20 with symbol, 50 without symbol"
        }
      ]
    },
    {
      "title": "Request Parameters",
      "level": 2,
      "id": "request-parameters",
      "blocks": [
        {
          "type": "table",
          "headers": [
            "Name",
            "Type",
            "Mandatory",
            "Description"
          ],
          "rows": [
            [
              "symbol",
              "STRING",
              "NO",
              ""
            ],
            [
              "autoCloseType",
              "ENUM",
              "NO",
              "\"LIQUIDATION\" for liquidation orders, \"ADL\" for ADL orders."
            ],
            [
              "startTime",
              "LONG",
              "NO",
              ""
            ],
            [
              "endTime",
              "LONG",
              "NO",
              ""
            ],
            [
              "limit",
              "INT",
              "NO",
              "Default 50; max 100."
            ],
            [
              "recvWindow",
              "LONG",
              "NO",
              ""
            ],
            [
              "timestamp",
              "LONG",
              "YES",
              ""
            ]
          ]
        },
        {
          "type": "blockquote",
          "text": "If \"autoCloseType\" is not sent, orders with both of the types will be returned If \"startTime\" is not sent, data within 7 days before \"endTime\" can be queried"
        }
      ]
    },
    {
