{
  "title": "Get Funding Rate History",
  "meta_description": "API Description",
  "intro_blocks": [],
  "sections": [
    {
      "title": "API Description",
      "level": 2,
      "id": "api-description",
      "blocks": [
        {
          "type": "paragraph",
          "text": "Get Funding Rate History"
        }
      ]
    },
    {
      "title": "HTTP Request",
      "level": 2,
      "id": "http-request",
      "blocks": [
        {
          "type": "paragraph",
          "text": "GET `/fapi/v1/fundingRate`"
        }
      ]
    },
    {
      "title": "Request Weight",
      "level": 2,
      "id": "request-weight",
      "blocks": [
        {
          "type": "paragraph",
          "text": "share 500/5min/IP rate limit with GET /fapi/v1/fundingInfo"
        }
      ]
    },
    {
      "title": "Request Parameters",
      "level": 2,
      "id": "request-parameters",
      "blocks": [
        {
          "type": "table",
          "headers": [
            "Name",
            "Type",
            "Mandatory",
            "Description"
          ],
          "rows": [
            [
              "symbol",
              "STRING",
              "NO",
              ""
            ],
            [
              "startTime",
              "LONG",
              "NO",
              "Timestamp in ms to get funding rate from INCLUSIVE."
            ],
            [
              "endTime",
              "LONG",
              "NO",
              "Timestamp in ms to get funding rate until INCLUSIVE."
            ],
            [
              "limit",
              "INT",
              "NO",
              "Default 100; max 1000"
            ]
          ]
        },
        {
          "type": "blockquote",
          "text": "If `startTime` and `endTime` are not sent, the most recent 200 records are returned. If the number of data between `startTime` and `endTime` is larger than `limit`, return as `startTime` + `limit`. In ascending order."
        }
      ]
    },
    {
      "title": "Response Example",
      "level": 2,
      "id": "response-example",
      "blocks": [
        {
          "type": "code",
          "language": "javascript",
          "text": "[\n{\n\"symbol\": \"BTCUSDT\",\n\"fundingRate\": \"-0.03750000\",\n\"fundingTime\": 1570608000000,\n\"markPrice\": \"34287.54619963\" // mark price associated with a particular funding fee charge\n},\n{\n\"symbol\": \"BTCUSDT\",\n\"fundingRate\": \"0.00010000\",\n\"fundingTime\": 1570636800000,\n\"markPrice\": \"34287.54619963\"\n}\n]"
        }
      ]
    }
  ],
