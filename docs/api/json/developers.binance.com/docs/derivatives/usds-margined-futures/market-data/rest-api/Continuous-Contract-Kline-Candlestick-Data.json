{
  "title": "Continuous Contract Kline/Candlestick Data",
  "meta_description": "API Description",
  "intro_blocks": [],
  "sections": [
    {
      "title": "API Description",
      "level": 2,
      "id": "api-description",
      "blocks": [
        {
          "type": "paragraph",
          "text": "Kline/candlestick bars for a specific contract type. Klines are uniquely identified by their open time."
        }
      ]
    },
    {
      "title": "HTTP Request",
      "level": 2,
      "id": "http-request",
      "blocks": [
        {
          "type": "paragraph",
          "text": "GET `/fapi/v1/continuousKlines`"
        }
      ]
    },
    {
      "title": "Request Weight",
      "level": 2,
      "id": "request-weight",
      "blocks": [
        {
          "type": "paragraph",
          "text": "based on parameter `LIMIT`"
        },
        {
          "type": "table",
          "headers": [
            "LIMIT",
            "weight"
          ],
          "rows": [
            [
              "[1,100)",
              "1"
            ],
            [
              "[100, 500)",
              "2"
            ],
            [
              "[500, 1000]",
              "5"
            ],
            [
              "> 1000",
              "10"
            ]
          ]
        }
      ]
    },
    {
      "title": "Request Parameters",
      "level": 2,
      "id": "request-parameters",
      "blocks": [
        {
          "type": "table",
          "headers": [
            "Name",
            "Type",
            "Mandatory",
            "Description"
          ],
          "rows": [
            [
              "pair",
              "STRING",
              "YES",
              ""
            ],
            [
              "contractType",
              "ENUM",
              "YES",
              ""
            ],
            [
              "interval",
              "ENUM",
              "YES",
              ""
            ],
            [
              "startTime",
              "LONG",
              "NO",
              ""
            ],
            [
              "endTime",
              "LONG",
              "NO",
              ""
            ],
            [
              "limit",
              "INT",
              "NO",
              "Default 500; max 1500."
            ]
          ]
        },
        {
          "type": "blockquote",
          "text": "If startTime and endTime are not sent, the most recent klines are returned."
        },
        {
          "type": "blockquote",
          "text": "Contract type: PERPETUAL CURRENT_QUARTER NEXT_QUARTER TRADIFI_PERPETUAL"
        }
      ]
    },
    {
      "title": "Response Example",
      "level": 2,
      "id": "response-example",
      "blocks": [
        {
          "type": "code",
          "language": "javascript",
          "text": "[\n[\n1607444700000, // Open time\n\"18879.99\", // Open\n\"18900.00\", // High\n\"18878.98\", // Low\n\"18896.13\", // Close (or latest price)\n\"492.363\", // Volume\n1607444759999, // Close time\n\"9302145.66080\", // Quote asset volume\n1874, // Number of trades\n\"385.983\", // Taker buy volume\n\"7292402.33267\", // Taker buy quote asset volume\n\"0\" // Ignore.\n]\n]"
        }
      ]
    }
  ],
  "protocol": "rest",
