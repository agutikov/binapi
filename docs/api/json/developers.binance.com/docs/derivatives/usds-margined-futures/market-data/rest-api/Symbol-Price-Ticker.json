{
  "title": "Symbol Price Ticker(Deprecated)",
  "meta_description": "API Description",
  "intro_blocks": [],
  "sections": [
    {
      "title": "API Description",
      "level": 2,
      "id": "api-description",
      "blocks": [
        {
          "type": "paragraph",
          "text": "Latest price for a symbol or symbols."
        }
      ]
    },
    {
      "title": "HTTP Request",
      "level": 2,
      "id": "http-request",
      "blocks": [
        {
          "type": "paragraph",
          "text": "GET `/fapi/v1/ticker/price`"
        },
        {
          "type": "paragraph",
          "text": "Weight:"
        },
        {
          "type": "paragraph",
          "text": "1 for a single symbol; 2 when the symbol parameter is omitted"
        }
      ]
    },
    {
      "title": "Request Parameters",
      "level": 2,
      "id": "request-parameters",
      "blocks": [
        {
          "type": "table",
          "headers": [
            "Name",
            "Type",
            "Mandatory",
            "Description"
          ],
          "rows": [
            [
              "symbol",
              "STRING",
              "NO",
              ""
            ]
          ]
        },
        {
          "type": "blockquote",
          "text": "If the symbol is not sent, prices for all symbols will be returned in an array."
        }
      ]
    },
    {
      "title": "Response Example",
      "level": 2,
      "id": "response-example",
      "blocks": [
        {
          "type": "code",
          "language": "javascript",
          "text": "{\n\"symbol\": \"BTCUSDT\",\n\"price\": \"6000.01\",\n\"time\": 1589437530011 // Transaction time\n}"
        },
        {
          "type": "blockquote",
          "text": "OR"
        },
        {
          "type": "code",
          "language": "json",
          "json": [
            {
              "symbol": "BTCUSDT",
              "price": "6000.01",
              "time": 1589437530011
            }
          ]
        }
      ]
    }
  ],
