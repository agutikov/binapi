{
  "title": "Symbol Order Book Ticker",
  "meta_description": "API Description",
  "intro_blocks": [],
  "sections": [
    {
      "title": "API Description",
      "level": 2,
      "id": "api-description",
      "blocks": [
        {
          "type": "paragraph",
          "text": "Best price/qty on the order book for a symbol or symbols."
        }
      ]
    },
    {
      "title": "Method",
      "level": 2,
      "id": "method",
      "blocks": [
        {
          "type": "paragraph",
          "text": "`ticker.book`"
        },
        {
          "type": "paragraph",
          "text": "Note:"
        },
        {
          "type": "blockquote",
          "text": "Retail Price Improvement(RPI) orders are not visible and excluded in the response message."
        }
      ]
    },
    {
      "title": "Request",
      "level": 2,
      "id": "request",
      "blocks": [
        {
          "type": "code",
          "language": "json",
          "json": {
            "id": "9d32157c-a556-4d27-9866-66760a174b57",
            "method": "ticker.book",
            "params": {
              "symbol": "BTCUSDT"
            }
          }
        }
      ]
    },
    {
      "title": "Request Weight",
      "level": 2,
      "id": "request-weight",
      "blocks": [
        {
          "type": "paragraph",
          "text": "2 for a single symbol; 5 when the symbol parameter is omitted"
        }
      ]
    },
    {
      "title": "Request Parameters",
      "level": 2,
      "id": "request-parameters",
      "blocks": [
        {
          "type": "table",
          "headers": [
            "Name",
            "Type",
            "Mandatory",
            "Description"
          ],
          "rows": [
            [
              "symbol",
              "STRING",
              "NO",
              ""
            ]
          ]
        },
        {
          "type": "blockquote",
          "text": "If the symbol is not sent, bookTickers for all symbols will be returned in an array. The field `X-MBX-USED-WEIGHT-1M` in response header is not accurate from this endpoint, please ignore."
        }
      ]
    },
    {
      "title": "Response Example",
      "level": 2,
      "id": "response-example",
      "blocks": [
        {
          "type": "code",
          "language": "javascript",
          "text": "{\n\"id\": \"9d32157c-a556-4d27-9866-66760a174b57\",\n\"status\": 200,\n\"result\": {\n\"lastUpdateId\": 1027024,\n\"symbol\": \"BTCUSDT\",\n\"bidPrice\": \"4.00000000\",\n\"bidQty\": \"431.00000000\",\n\"askPrice\": \"4.00000200\",\n\"askQty\": \"9.00000000\",\n\"time\": 1589437530011 // Transaction time\n},\n\"rateLimits\": [\n{\n\"rateLimitType\": \"REQUEST_WEIGHT\",\n\"interval\": \"MINUTE\",\n\"intervalNum\": 1,\n\"limit\": 2400,\n\"count\": 2\n}\n]\n}"
        },
        {
          "type": "blockquote",
          "text": "OR"
        },
        {
          "type": "code",
          "language": "json",
          "json": {
            "id": "9d32157c-a556-4d27-9866-66760a174b57",
            "status": 200,
            "result": [
              {
                "lastUpdateId": 1027024,
                "symbol": "BTCUSDT",
                "bidPrice": "4.00000000",
                "bidQty": "431.00000000",
                "askPrice": "4.00000200",
                "askQty": "9.00000000",
                "time": 1589437530011
              }
            ],
            "rateLimits": [
              {
                "rateLimitType": "REQUEST_WEIGHT",
                "interval": "MINUTE",
                "intervalNum": 1,
                "limit": 2400,
                "count": 2
              }
            ]
          }
        }
      ]
    }
  ],
  "protocol": "websocket_api",
  "category": "websocket-api",
  "path_parts": [
