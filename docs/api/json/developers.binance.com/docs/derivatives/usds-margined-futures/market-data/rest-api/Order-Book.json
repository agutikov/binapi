        }
      ]
    },
    {
      "title": "HTTP Request",
      "level": 2,
      "id": "http-request",
      "blocks": [
        {
          "type": "paragraph",
          "text": "GET `/fapi/v1/depth`"
        },
        {
          "type": "paragraph",
          "text": "Note:"
        },
        {
          "type": "blockquote",
          "text": "Retail Price Improvement(RPI) orders are not visible and excluded in the response message."
        }
      ]
    },
    {
      "title": "Request Weight",
      "level": 2,
      "id": "request-weight",
      "blocks": [
        {
          "type": "paragraph",
          "text": "Adjusted based on the limit:"
        },
        {
          "type": "table",
          "headers": [
            "Limit",
            "Weight"
          ],
          "rows": [
            [
              "5, 10, 20, 50",
              "2"
            ],
            [
              "100",
              "5"
            ],
            [
              "500",
              "10"
            ],
            [
              "1000",
              "20"
            ]
          ]
        }
      ]
    },
    {
      "title": "Request Parameters",
      "level": 2,
      "id": "request-parameters",
      "blocks": [
        {
          "type": "table",
          "headers": [
            "Name",
            "Type",
            "Mandatory",
            "Description"
          ],
          "rows": [
            [
              "symbol",
              "STRING",
              "YES",
              ""
            ],
            [
              "limit",
              "INT",
              "NO",
              "Default 500; Valid limits:[5, 10, 20, 50, 100, 500, 1000]"
            ]
          ]
        }
      ]
    },
